# ========== ComfyUI 连接配置 ==========
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# ========== LM Studio 连接配置（可选） ==========
LMS_HOST=127.0.0.1
LMS_PORT=1234

# ========== Web 服务配置 ==========
WEB_HOST=127.0.0.1
WEB_PORT=8080

# ========== 目录路径（必填） ==========
# ComfyUI 输出目录（只读浏览）
OUTPUT_DIR_STR=C:\path\to\ComfyUI\output
# ComfyUI 工作流目录（自动扫描）
COMFYUI_WORKFLOWS_DIR=C:\path\to\ComfyUI\user\default\workflows

# ========== 工作流子目录名 ==========
WF_DIR_TXT2IMG=文生图
WF_DIR_IMG2IMG=图生图
# 图生图自动工作流（可选，留空则自动扫描）
IMG2IMG_WORKFLOW_SINGLE=
IMG2IMG_WORKFLOW_DUAL=

# ========== GitHub OAuth（必填） ==========
# 在 https://github.com/settings/developers 创建 OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========== 站点域名 ==========
SITE_URL=http://localhost:8080

# ========== 开发模式 ==========
# 设为 1 可跳过 GitHub OAuth，使用 /auth/dev_login 测试
DEV_MODE=0

# ========== 信任的代理 IP ==========
# 逗号分隔，设为 * 信任所有（危险！），设为空不信任任何代理
TRUSTED_PROXY_IPS=127.0.0.1,::1

# ========== LLM API Key 加密密钥（可选） ==========
# 用于加密存储 LLM API Key，留空则明文存储
LLM_ENCRYPTION_KEY=

# ========== 邮箱服务配置（QQ邮箱SMTP） ==========
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的QQ号@qq.com
SMTP_PASS=QQ邮箱授权码
SITE_NAME=二次元绘梦

# Cloudflare Turnstile 人机验证（在 dash.cloudflare.com 获取）
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 注册限流（邀请码注册，可在管理面板在线修改）
REG_HOURLY_LIMIT_PER_IP=3
REG_DAILY_LIMIT_PER_IP=10
REG_DAILY_LIMIT_PER_EMAIL=3

# 全局发信上限（每天）
EMAIL_GLOBAL_DAILY_LIMIT=250
