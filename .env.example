# ========== ComfyUI 连接配置 ==========
COMFYUI_HOST=127.0.0.1
COMFYUI_PORT=8188

# ========== LM Studio 连接配置（可选） ==========
LMS_HOST=127.0.0.1
LMS_PORT=1234

# ========== Web 服务配置 ==========
WEB_HOST=127.0.0.1
WEB_PORT=23601

# ========== 目录路径（必填） ==========
# ComfyUI 输出目录（只读浏览）
OUTPUT_DIR_STR=C:\path\to\ComfyUI\output
# ComfyUI 工作流目录（自动扫描）
COMFYUI_WORKFLOWS_DIR=C:\path\to\ComfyUI\user\default\workflows

# ========== 工作流子目录名 ==========
WF_DIR_TXT2IMG=文生图
WF_DIR_IMG2IMG=图生图
# 图生图自动工作流（可选，留空则自动扫描）
IMG2IMG_WORKFLOW_SINGLE=
IMG2IMG_WORKFLOW_DUAL=

# ========== GitHub OAuth（必填） ==========
# 在 https://github.com/settings/developers 创建 OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ========== 站点域名 ==========
SITE_URL=http://localhost:23601

# ========== 开发模式 ==========
# 设为 1 可跳过 GitHub OAuth，使用 /auth/dev_login 测试
DEV_MODE=0
# DEV_MODE=1 且 SITE_URL 已配置时需额外设置 DEV_MODE_ALLOW_UNSAFE=1
# DEV_MODE_ALLOW_UNSAFE=0

# ========== 管理员提权密码（敏感操作二次验证） ==========
# 未设置时跳过二次验证（向后兼容）
# 生成: python -c "import hashlib,secrets; s=secrets.token_hex(16); print(s+':'+hashlib.pbkdf2_hmac('sha256',b'你的密码',s.encode(),200000).hex())"
# ADMIN_ELEVATION_PASSWORD=

# ========== 初始管理员（可选） ==========
# 1=首个注册/登录用户自动成为管理员（默认，适合私有部署）；0=关闭（公网推荐）
FIRST_USER_ADMIN=1
# 逗号分隔的用户唯一 ID，只加管理员权限，不撤销已有管理员。
# GitHub 用户填数字 ID；邮箱用户填 email:邮箱地址，例如：163757981,email:admin@example.com
INITIAL_ADMIN_USER_IDS=

# ========== 访问日志（可选） ==========
# 1=HTTP 日志显示用户唯一 ID（便于配置 INITIAL_ADMIN_USER_IDS，会暴露邮箱型 ID）；0=只显示登录名
LOG_USER_ID=0

# ========== 信任的代理 IP ==========
# 逗号分隔，设为 * 信任所有（危险！），设为空不信任任何代理
TRUSTED_PROXY_IPS=127.0.0.1,::1

# ========== LLM API Key 加密密钥（可选） ==========
# 用于加密存储 LLM API Key，留空则明文存储
LLM_ENCRYPTION_KEY=

# ========== 邮箱服务配置（SMTP 发信） ==========
# 支持任意 SMTP 服务商，常见配置：
#   QQ邮箱:    smtp.qq.com       465 (SSL)   需开启SMTP服务获取授权码
#   163邮箱:   smtp.163.com      465 (SSL)   需开启SMTP服务获取授权码
#   Gmail:     smtp.gmail.com    587 (STARTTLS) 需开启两步验证+应用专用密码
#   Outlook:   smtp.office365.com 587 (STARTTLS)
#   阿里企业邮: smtp.mxhichina.com 465 (SSL)
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=你的邮箱地址
SMTP_PASS=邮箱授权码或密码
SITE_NAME=项目名字

# Cloudflare Turnstile 人机验证（在 dash.cloudflare.com 获取）
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 注册限流（邀请码注册，可在管理面板在线修改）
REG_HOURLY_LIMIT_PER_IP=3
REG_DAILY_LIMIT_PER_IP=10
REG_DAILY_LIMIT_PER_EMAIL=3

# 全局发信上限（每天）
EMAIL_GLOBAL_DAILY_LIMIT=250

# 全局发信上限（每分钟）
EMAIL_GLOBAL_MINUTE_LIMIT=10

# IP 白名单（逗号分隔，黑名单也管不到，用于管理豁免）
# 启动时自动同步到数据库，已在数据库中的不受影响
IP_WHITELIST=127.0.0.1,::1

# 签名下载链接密钥（随机字符串，留空则用代码内默认值）
# DL_SECRET_KEY=

# 联系管理员（用户看到的联系邮箱，与发信账号可不同）
CONTACT_EMAIL=admin@你的邮箱域名
# 验证邮件重试次数
VERIFY_MAX_RETRIES=3
# 同IP恶意标记阈值
VERIFY_ABUSE_THRESHOLD=3

# ========== SPA 静态文件缓存（可选） ==========
# 前端构建后的 JS/CSS 带 hash 指纹，可安全地永久缓存
# 0=不缓存（开发推荐），31536000=一年缓存（生产推荐）
SPA_CACHE_MAX_AGE=0

# ========== MySQL 数据库（MySQL 版必需） ==========
# 使用绿色便携版时默认配置即可
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=你的数据库密码
MYSQL_DATABASE=natureDrawImage
